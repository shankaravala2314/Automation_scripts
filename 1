#!/bin/bash

# ==========================================
# CHANGE ONLY BELOW VALUES
# ==========================================

SOURCE="I:\\Part_2\\Data\\Kanpur\\test"

DESTINATION="sysgrid/store-igenesys/kanpur/test"

MC_PATH="/mnt/c/mc/mc.exe"

# ==========================================
# LOG FILE
# ==========================================

LOG_DIR="logs"
mkdir -p "$LOG_DIR"

TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
LOG_FILE="$LOG_DIR/upload_$TIMESTAMP.log"

# ==========================================
# START
# ==========================================

echo "=================================================="
echo "UPLOAD STARTED"
echo "=================================================="

echo "Source      : $SOURCE"
echo "Destination : $DESTINATION"
echo "Log File    : $LOG_FILE"

echo ""
echo "Uploading..."
echo ""

# ==========================================
# RUN COMMAND
# ==========================================

"$MC_PATH" mirror --overwrite --retry "$SOURCE" "$DESTINATION" | tee "$LOG_FILE"

# ==========================================
# STATUS
# ==========================================

if [ ${PIPESTATUS[0]} -eq 0 ]; then
    echo ""
    echo "=================================================="
    echo "UPLOAD COMPLETED SUCCESSFULLY"
    echo "=================================================="
else
    echo ""
    echo "=================================================="
    echo "UPLOAD FAILED"
    echo "=================================================="
fi
